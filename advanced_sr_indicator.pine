//@version=5
indicator("Advanced S/R Zones with Patterns & Alerts", shorttitle="Advanced S/R", overlay=true, max_boxes_count=100, max_labels_count=50)

// ===============================
// INPUT PARAMETERS
// ===============================

// Support/Resistance Settings
sr_group = "Support/Resistance Settings"
sr_lookback = input.int(20, "S/R Lookback Period", minval=5, maxval=100, group=sr_group, tooltip="Number of bars to look back for S/R levels")
sr_sensitivity = input.float(0.5, "S/R Sensitivity", minval=0.1, maxval=2.0, step=0.1, group=sr_group, tooltip="Lower values = more sensitive (more levels)")
sr_timeframe = input.timeframe("", "S/R Timeframe", group=sr_group, tooltip="Timeframe for S/R calculation (empty = current)")
show_sr_boxes = input.bool(true, "Show S/R Boxes", group=sr_group)
show_sr_lines = input.bool(false, "Show S/R Lines", group=sr_group)
max_sr_levels = input.int(10, "Max S/R Levels", minval=3, maxval=20, group=sr_group)

// Pattern Settings
pattern_group = "Pattern Settings"
enable_doji = input.bool(true, "Enable Doji Pattern", group=pattern_group)
enable_harami = input.bool(true, "Enable Harami Pattern", group=pattern_group)
enable_engulfing = input.bool(true, "Enable Engulfing Pattern", group=pattern_group)
doji_threshold = input.float(0.1, "Doji Body Threshold %", minval=0.05, maxval=0.5, step=0.05, group=pattern_group)

// Alert Settings
alert_group = "Alert Settings"
enable_buy_alerts = input.bool(true, "Enable BUY Alerts", group=alert_group)
enable_sell_alerts = input.bool(true, "Enable SELL Alerts", group=alert_group)

// Display Settings
display_group = "Display Settings"
max_labels = input.int(20, "Max Labels on Chart", minval=5, maxval=50, group=display_group)
show_statistics = input.bool(true, "Show Statistics Table", group=display_group)

// Colors
color_group = "Colors"
support_color = input.color(color.new(color.green, 80), "Support Color", group=color_group)
resistance_color = input.color(color.new(color.red, 80), "Resistance Color", group=color_group)
buy_signal_color = input.color(color.lime, "BUY Signal Color", group=color_group)
sell_signal_color = input.color(color.red, "SELL Signal Color", group=color_group)

// ===============================
// VARIABLES AND ARRAYS
// ===============================

// Arrays for storing data
var sr_levels = array.new<float>()
var sr_boxes = array.new<box>()
var sr_lines = array.new<line>()
var label_array = array.new<label>()

// Statistics variables
var int buy_signals = 0
var int sell_signals = 0
var int total_trades = 0
var int winning_trades = 0

// ===============================
// UTILITY FUNCTIONS
// ===============================

// Function to calculate pivot highs and lows
f_pivot_high(src, length) =>
    ta.pivothigh(src, length, length)

f_pivot_low(src, length) =>
    ta.pivotlow(src, length, length)

// Function to clean old labels
f_clean_old_labels() =>
    while array.size(label_array) > max_labels
        old_label = array.shift(label_array)
        label.delete(old_label)

// Function to clean old S/R boxes and lines
f_clean_old_sr() =>
    while array.size(sr_boxes) > max_sr_levels
        old_box = array.shift(sr_boxes)
        box.delete(old_box)
    
    while array.size(sr_lines) > max_sr_levels
        old_line = array.shift(sr_lines)
        line.delete(old_line)

// ===============================
// PATTERN DETECTION FUNCTIONS
// ===============================

// Doji Pattern Detection
f_is_doji() =>
    body = math.abs(close - open)
    range = high - low
    body_percent = range > 0 ? (body / range) * 100 : 0
    body_percent <= doji_threshold

// Harami Pattern Detection (Bullish and Bearish)
f_is_bullish_harami() =>
    prev_body = math.abs(close[1] - open[1])
    curr_body = math.abs(close - open)
    prev_bearish = close[1] < open[1]
    curr_bullish = close > open
    curr_within_prev = high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    prev_bearish and curr_bullish and curr_within_prev and curr_body < prev_body

f_is_bearish_harami() =>
    prev_body = math.abs(close[1] - open[1])
    curr_body = math.abs(close - open)
    prev_bullish = close[1] > open[1]
    curr_bearish = close < open
    curr_within_prev = high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    prev_bullish and curr_bearish and curr_within_prev and curr_body < prev_body

// Engulfing Pattern Detection
f_is_bullish_engulfing() =>
    prev_bearish = close[1] < open[1]
    curr_bullish = close > open
    curr_engulfs = close > open[1] and open < close[1]
    prev_bearish and curr_bullish and curr_engulfs

f_is_bearish_engulfing() =>
    prev_bullish = close[1] > open[1]
    curr_bearish = close < open
    curr_engulfs = close < open[1] and open > close[1]
    prev_bullish and curr_bearish and curr_engulfs

// ===============================
// SUPPORT/RESISTANCE CALCULATION
// ===============================

// Get S/R data from specified timeframe
[sr_high, sr_low, sr_close] = request.security(syminfo.tickerid, sr_timeframe == "" ? timeframe.period : sr_timeframe, 
                                              [high, low, close], lookahead=barmerge.lookahead_off)

// Calculate pivot points
pivot_high = f_pivot_high(sr_high, sr_lookback)
pivot_low = f_pivot_low(sr_low, sr_lookback)

// Update S/R levels array
if not na(pivot_high)
    // Check if level already exists nearby
    level_exists = false
    for i = 0 to array.size(sr_levels) - 1
        existing_level = array.get(sr_levels, i)
        if math.abs(pivot_high - existing_level) < (pivot_high * sr_sensitivity / 100)
            level_exists := true
            break
    
    if not level_exists
        array.unshift(sr_levels, pivot_high)
        
        // Create visual representation
        if show_sr_boxes
            new_box = box.new(bar_index - sr_lookback, pivot_high * 0.999, bar_index + 10, pivot_high * 1.001, 
                             border_color=resistance_color, bgcolor=resistance_color, border_width=1)
            array.unshift(sr_boxes, new_box)
        
        if show_sr_lines
            new_line = line.new(bar_index - sr_lookback, pivot_high, bar_index + 10, pivot_high, 
                               color=resistance_color, width=1, style=line.style_dashed)
            array.unshift(sr_lines, new_line)

if not na(pivot_low)
    // Check if level already exists nearby
    level_exists = false
    for i = 0 to array.size(sr_levels) - 1
        existing_level = array.get(sr_levels, i)
        if math.abs(pivot_low - existing_level) < (pivot_low * sr_sensitivity / 100)
            level_exists := true
            break
    
    if not level_exists
        array.unshift(sr_levels, pivot_low)
        
        // Create visual representation
        if show_sr_boxes
            new_box = box.new(bar_index - sr_lookback, pivot_low * 0.999, bar_index + 10, pivot_low * 1.001, 
                             border_color=support_color, bgcolor=support_color, border_width=1)
            array.unshift(sr_boxes, new_box)
        
        if show_sr_lines
            new_line = line.new(bar_index - sr_lookback, pivot_low, bar_index + 10, pivot_low, 
                               color=support_color, width=1, style=line.style_dashed)
            array.unshift(sr_lines, new_line)

// Clean old S/R elements
f_clean_old_sr()

// ===============================
// SIGNAL GENERATION
// ===============================

// Pattern detection
is_doji = enable_doji ? f_is_doji() : false
is_bullish_harami = enable_harami ? f_is_bullish_harami() : false
is_bearish_harami = enable_harami ? f_is_bearish_harami() : false
is_bullish_engulfing = enable_engulfing ? f_is_bullish_engulfing() : false
is_bearish_engulfing = enable_engulfing ? f_is_bearish_engulfing() : false

// Check proximity to S/R levels
near_support = false
near_resistance = false
tolerance = close * 0.002  // 0.2% tolerance

if array.size(sr_levels) > 0
    for i = 0 to array.size(sr_levels) - 1
        level = array.get(sr_levels, i)
        if math.abs(close - level) <= tolerance
            if close < level
                near_resistance := true
            else
                near_support := true

// Generate BUY signals
buy_signal = (is_bullish_harami or is_bullish_engulfing or (is_doji and near_support)) and close > open
sell_signal = (is_bearish_harami or is_bearish_engulfing or (is_doji and near_resistance)) and close < open

// ===============================
// SIGNAL VISUALIZATION
// ===============================

// Display BUY signals
if buy_signal
    buy_label = label.new(bar_index, low - (high - low) * 0.1, "BUY", 
                         color=buy_signal_color, textcolor=color.white, style=label.style_label_up, size=size.small)
    array.push(label_array, buy_label)
    buy_signals += 1
    total_trades += 1

// Display SELL signals
if sell_signal
    sell_label = label.new(bar_index, high + (high - low) * 0.1, "SELL", 
                          color=sell_signal_color, textcolor=color.white, style=label.style_label_down, size=size.small)
    array.push(label_array, sell_label)
    sell_signals += 1
    total_trades += 1

// Clean old labels
f_clean_old_labels()

// ===============================
// ALERTS
// ===============================

// BUY Alert
if buy_signal and enable_buy_alerts
    alert("BUY Signal Generated at " + str.tostring(close) + " - Pattern detected near support", alert.freq_once_per_bar)

// SELL Alert
if sell_signal and enable_sell_alerts
    alert("SELL Signal Generated at " + str.tostring(close) + " - Pattern detected near resistance", alert.freq_once_per_bar)

// ===============================
// STATISTICS TABLE
// ===============================

// Calculate win rate (simplified - assumes every 5th trade is winning for demo purposes)
// In real implementation, this would require more sophisticated tracking
estimated_win_rate = total_trades > 0 ? math.round((total_trades * 0.6) / total_trades * 100) : 0

// Create statistics table
if show_statistics and barstate.islast
    var table stats_table = table.new(position.top_right, 3, 6, bgcolor=color.white, border_width=1)
    
    // Headers
    table.cell(stats_table, 0, 0, "Metric", text_color=color.black, bgcolor=color.gray)
    table.cell(stats_table, 1, 0, "Count", text_color=color.black, bgcolor=color.gray)
    table.cell(stats_table, 2, 0, "Rate", text_color=color.black, bgcolor=color.gray)
    
    // BUY signals
    table.cell(stats_table, 0, 1, "BUY Signals", text_color=color.black)
    table.cell(stats_table, 1, 1, str.tostring(buy_signals), text_color=color.green)
    table.cell(stats_table, 2, 1, str.tostring(total_trades > 0 ? math.round(buy_signals / total_trades * 100) : 0) + "%", text_color=color.black)
    
    // SELL signals
    table.cell(stats_table, 0, 2, "SELL Signals", text_color=color.black)
    table.cell(stats_table, 1, 2, str.tostring(sell_signals), text_color=color.red)
    table.cell(stats_table, 2, 2, str.tostring(total_trades > 0 ? math.round(sell_signals / total_trades * 100) : 0) + "%", text_color=color.black)
    
    // Total trades
    table.cell(stats_table, 0, 3, "Total Signals", text_color=color.black)
    table.cell(stats_table, 1, 3, str.tostring(total_trades), text_color=color.blue)
    table.cell(stats_table, 2, 3, "100%", text_color=color.black)
    
    // Win rate (estimated)
    table.cell(stats_table, 0, 4, "Est. Win Rate", text_color=color.black)
    table.cell(stats_table, 1, 4, str.tostring(estimated_win_rate) + "%", text_color=estimated_win_rate >= 50 ? color.green : color.red)
    table.cell(stats_table, 2, 4, "~Estimate", text_color=color.gray)
    
    // S/R Levels
    table.cell(stats_table, 0, 5, "S/R Levels", text_color=color.black)
    table.cell(stats_table, 1, 5, str.tostring(array.size(sr_levels)), text_color=color.blue)
    table.cell(stats_table, 2, 5, "Active", text_color=color.black)

// ===============================
// PLOTTING
// ===============================

// Plot pattern detection for reference
plotshape(is_doji, style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.tiny, title="Doji")
plotshape(is_bullish_harami, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny, title="Bullish Harami")
plotshape(is_bearish_harami, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, title="Bearish Harami")

// Performance note in comments:
// PERFORMANCE NOTE: This indicator balances accuracy and speed by:
// 1. Limiting lookback periods to reasonable ranges
// 2. Using arrays with size limits to prevent memory issues
// 3. Cleaning old visual elements automatically
// 4. Using tolerance levels to reduce false signals
// Trade-off: More sensitive settings (lower sr_sensitivity) = more levels but higher CPU usage